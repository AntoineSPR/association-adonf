---
import "primeicons/primeicons.css";
import "../styles/global.scss";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { resolvePath } from "../lib/utils";
import { getApiUrl } from "../lib/api";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Association Adonf - École de musique & Concerts à Montendre",
  image = "/assets/logo-adonf.png"
} = Astro.props;

let parametres = {
  billetterieUrl: "https://www.helloasso.com/associations/a-d-onf",
  logoImage: "/assets/logo-adonf.png",
  adressePhysique: {
    nom: "Association Adonf",
    ligne1: "29 avenue de Onda",
    ligne2: "17130 Montendre",
    telephone: "05 46 49 03 18",
  },
  reseauxSociaux: [
    { label: "Facebook", iconId: "FacebookIcon", url: "https://www.facebook.com/AssociationADonf/" },
    { label: "Instagram", iconId: "InstagramIcon", url: "https://www.instagram.com/association_adonf/" },
    { label: "YouTube", iconId: "YoutubeIcon", url: "https://www.youtube.com/channel/UCiP4wYd6e2iLz6F-0Wf-cWA" },
  ],
};

if (typeof process !== "undefined" && import.meta.env.DEV) {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = "0";
}

try {
  const API_URL = getApiUrl();
  const res = await fetch(`${API_URL}/api/PageContent/contenu-global`);
  if (res.ok) {
    const data = await res.json();
    if (data?.content && Object.keys(data.content).length > 0) {
      parametres = { ...parametres, ...data.content };
    }
  }
} catch (e) {
  console.error("Impossible de charger le contenu global (Layout)", e);
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={resolvePath("/favicon.ico")} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(resolvePath(image), Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(resolvePath(image), Astro.url)} />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Lien d'évitement / Skip Link -->
    <a
      href="#contenu-main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[10000] focus:px-4 focus:py-2 focus:bg-[var(--primary-color)] focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white left-0 top-0 m-2 rounded"
    >
      Aller au contenu principal
    </a>
    <Header parametres={parametres} />
    <main
      id="contenu-main"
      class="flex-1 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--primary-color)] focus-visible:ring-offset-2"
      aria-label="Contenu principal"
      tabindex="-1"
    >
      <slot />
    </main>
    <Footer parametres={parametres} />
  </body>
</html>
