---
import "primeicons/primeicons.css";
import "../styles/global.scss";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { resolvePath } from "../lib/utils";
import { getApiUrl } from "../lib/api";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: "website" | "article" | "music.song" | "music.event";
}

const {
  title,
  description = "Association Adonf - École de musique & Concerts à Montendre",
  image = "/assets/logo-adonf.png",
  canonicalUrl = new URL(Astro.url.pathname, Astro.site || Astro.url.href).href,
  type = "website",
} = Astro.props;

let parametres = {
  billetterieUrl: "https://www.helloasso.com/associations/a-d-onf",
  logoImage: "/assets/logo-adonf.png",
  adressePhysique: {
    nom: "Association Adonf",
    ligne1: "29 avenue de Onda",
    ligne2: "17130 Montendre",
    telephone: "05 46 49 03 18",
  },
  reseauxSociaux: [
    { label: "Facebook", iconId: "FacebookIcon", url: "https://www.facebook.com/AssociationADonf/" },
    { label: "Instagram", iconId: "InstagramIcon", url: "https://www.instagram.com/association_adonf/" },
    { label: "YouTube", iconId: "YoutubeIcon", url: "https://www.youtube.com/channel/UCiP4wYd6e2iLz6F-0Wf-cWA" },
  ],
};

if (typeof process !== "undefined" && import.meta.env.DEV) {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = "0";
}

try {
  const API_URL = getApiUrl();
  const res = await fetch(`${API_URL}/api/PageContent/contenu-global`);
  if (res.ok) {
    const data = await res.json();
    if (data?.content && Object.keys(data.content).length > 0) {
      parametres = { ...parametres, ...data.content };
    }
  }
} catch (e) {
  console.error("Impossible de charger le contenu global (Layout)", e);
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href={resolvePath("/favicon.ico")} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- SEO / Indexing -->
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(resolvePath(image), Astro.site || Astro.url)} />
    <meta property="og:site_name" content="Association Adonf" />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(resolvePath(image), Astro.site || Astro.url)} />

    <!-- JSON-LD (Schema.org) for Local Music School -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MusicSchool",
        name: "Association Adonf",
        url: Astro.site ? Astro.site.origin : "https://associationadonf.fr",
        logo: new URL(resolvePath("/assets/logo-adonf.png"), Astro.site || Astro.url).href,
        address: {
          "@type": "PostalAddress",
          streetAddress: parametres.adressePhysique.ligne1,
          addressLocality: parametres.adressePhysique.ligne2.replace(/[0-9]/g, "").trim(),
          postalCode: parametres.adressePhysique.ligne2.replace(/\D/g, "").trim(),
          addressCountry: "FR",
        },
        telephone: parametres.adressePhysique.telephone,
        sameAs: parametres.reseauxSociaux.map((s) => s.url),
      })}
    />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Lien d'évitement / Skip Link -->
    <a
      href="#contenu-main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[10000] focus:px-4 focus:py-2 focus:bg-[var(--primary-color)] focus:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white left-0 top-0 m-2 rounded"
    >
      Aller au contenu principal
    </a>
    <Header parametres={parametres} />
    <main
      id="contenu-main"
      class="flex-1 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--primary-color)] focus-visible:ring-offset-2"
      aria-label="Contenu principal"
      tabindex="-1"
    >
      <slot />
    </main>
    <Footer parametres={parametres} />
  </body>
</html>
