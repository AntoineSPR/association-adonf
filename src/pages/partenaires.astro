---
import EnConstruction from "../components/ui/EnConstruction.astro";
import { isEmptyContent } from "../lib/utils";
import Layout from "../layouts/Layout.astro";
import PartnerCard from "../components/PartnerCard.astro";
import { getApiUrl } from "../lib/api";

const API_URL = getApiUrl();
let partenaires = [];

if (typeof process !== "undefined" && import.meta.env.DEV) {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = "0";
}

try {
  const res = await fetch(`${API_URL}/api/PageContent/partenaires`);
  if (res.ok) {
    const data = await res.json();
    let parsedContent = data.content;
    if (typeof parsedContent === "string") {
      parsedContent = JSON.parse(parsedContent);
    }
    if (parsedContent && Array.isArray(parsedContent.partenaires)) {
      partenaires = parsedContent.partenaires;
    }
  }
} catch (e) {
  console.error("Failed to load partenaires", e);
}
---

<Layout title="Nos Partenaires - Association Adonf">
  <div class="page-container">
    <header class="page-header">
      <h1 class="main-title">NOS <span>PARTENAIRES</span></h1>
      <div class="title-underline"></div>
    </header>
    {(!partenaires || partenaires.length === 0) ? <EnConstruction /> : (
      <>
        

    <div class="partners-grid">
      {partenaires.map((partner) => <PartnerCard {...partner} />)}
    </div>
  
      </>
    )}
  </div>
</Layout>

<style>
  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 5rem;
  }
</style>
