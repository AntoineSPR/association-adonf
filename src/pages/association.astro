---
import EnConstruction from "../components/ui/EnConstruction.astro";
import { isEmptyContent } from "../lib/utils";
import Layout from "../layouts/Layout.astro";
import ContactList from "../components/ContactList.astro";
import { resolvePath } from "@/lib/utils";
import { getApiUrl } from "../lib/api";

const API_URL = getApiUrl();
let pageContent = null;

if (typeof process !== "undefined" && import.meta.env.DEV) {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = "0";
}

try {
  const res = await fetch(`${API_URL}/api/PageContent/association`);
  if (res.ok) {
    const data = await res.json();
    let parsedContent = data.content;
    if (typeof parsedContent === "string") {
      parsedContent = JSON.parse(parsedContent);
    }
    pageContent = parsedContent;
  }
} catch (e) {
  console.error("Failed to load page content", e);
}

const content = pageContent || {
  titrePartie1: "L'ASSOCIATION",
  titrePartie2: "",
  sections: [],
  contacts: [],
};
---

<Layout title={"Association Adonf"}>
  <div class="page-container">
    <header class="page-header">
      <h1 class="main-title">
        {content.titrePartie1}
        {content.titrePartie2 && <span>{content.titrePartie2}</span>}
      </h1>
      <div class="title-underline"></div>
    </header>
    {
      isEmptyContent(pageContent) ? (
        <EnConstruction />
      ) : (
        <>
          <div class="content-wrapper">
            {content.sections &&
              content.sections.map((section: any) => (
                <section class="info-section">
                  {section.titre && <h2 class="section-title">{section.titre}</h2>}
                  <div class="text-container" set:html={section.contenuHtml} />
                </section>
              ))}
          </div>

          <ContactList contacts={content.contacts} />
        </>
      )
    }
  </div>
</Layout>

<style>
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-section {
    background: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary-color, #dc143c);
  }

  .text-container :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .text-container :global(li) {
    margin-bottom: 0.5rem;
  }

  .text-container :global(a.btn) {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--primary-color, #dc143c);
    color: white;
    text-decoration: none;
    border-radius: 4px;
    margin-top: 0.5rem;
    margin-right: 0.5rem;
  }

  .text-container :global(a.btn:hover) {
    background-color: #b01030;
  }

  .mt-5 {
    margin-top: 3rem;
  }
</style>
