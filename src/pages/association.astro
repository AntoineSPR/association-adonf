---
import EnConstruction from "../components/ui/EnConstruction.astro";
import { isEmptyContent } from "../lib/utils";
import Layout from "../layouts/Layout.astro";
import ContactList from "../components/ContactList.astro";
import { resolvePath } from "@/lib/utils";
import { getApiUrl } from "../lib/api";

const API_URL = getApiUrl();
let pageContent = null;

if (typeof process !== "undefined" && import.meta.env.DEV) {
  process.env.NODE_TLS_REJECT_UNAUTHORIZED = "0";
}

try {
  const res = await fetch(`${API_URL}/api/PageContent/association`);
  if (res.ok) {
    const data = await res.json();
    let parsedContent = data.content;
    if (typeof parsedContent === "string") {
      parsedContent = JSON.parse(parsedContent);
    }
    pageContent = parsedContent;
  }
} catch (e) {
  console.error("Failed to load page content", e);
}

const content = pageContent || {
  titrePartie1: "L'ASSOCIATION",
  titrePartie2: "",
  documents: [],
  sections: [],
  contacts: [],
};
---

<Layout title={"Association Adonf"}>
  <div class="page-container">
    <header class="page-header">
      <h1 class="main-title">
        {content.titrePartie1}
        {content.titrePartie2 && <span>{content.titrePartie2}</span>}
      </h1>
      <div class="title-underline"></div>
    </header>
    {
      isEmptyContent(pageContent) ? (
        <EnConstruction />
      ) : (
        <>
          <div class="content-wrapper">
            {content.sections &&
              content.sections.map((section: any) => {
                const hasTitle = section.titre && section.titre.trim() !== "";
                const hasContent = section.contenuHtml && section.contenuHtml.trim() !== "" && section.contenuHtml !== "<p><br></p>";
                if (!hasTitle && !hasContent) return null;

                return (
                  <section class="info-section">
                    {section.titre && <h2 class="section-title">{section.titre}</h2>}
                    {section.contenuHtml && <div class="text-container" set:html={section.contenuHtml} />}
                  </section>
                );
              })}
            {content.documents && content.documents.length > 0 && (
              <div style="margin-bottom: 2rem; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 1rem; flex-wrap: wrap;">
                {content.documents.map((doc: any) =>
                  doc.fichierDocument ? (
                    <a href={doc.fichierDocument} target="_blank" rel="noopener noreferrer" class="btn pdf-btn">
                      <i class="pi pi-file-pdf" /> {doc.titreBouton || "Télécharger le document"}
                    </a>
                  ) : null,
                )}
              </div>
            )}
          </div>

          <ContactList contacts={content.contacts} />
        </>
      )
    }
  </div>
</Layout>

<style>
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-section {
    background: #f9f9f9;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary-color, #dc143c);
  }

  .text-container :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .text-container :global(li) {
    margin-bottom: 0.5rem;
  }

  .pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary-color, #dc143c);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
    font-size: 1.1rem;
    transition: all 0.2s ease-in-out;
  }

  .pdf-btn:hover {
    background-color: #b01030;
    transform: translateY(-2px);
  }

  .text-container :global(a.btn) {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: var(--primary-color, #dc143c);
    color: white;
    text-decoration: none;
    border-radius: 4px;
    margin-top: 0.5rem;
    margin-right: 0.5rem;
  }

  .text-container :global(a.btn:hover) {
    background-color: #b01030;
  }

  .mt-5 {
    margin-top: 3rem;
  }
</style>
