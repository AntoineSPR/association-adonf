---
import Layout from "../layouts/Layout.astro";
import ActualiteCard from "../components/ActualiteCard.astro";
import ConcertCard from "../components/ConcertCard.astro";
import { actualites } from "../data/mock";
import { ArrowRightIcon } from "../components/ui/icons";
import { resolvePath } from "../lib/utils";
import { getApiUrl } from "../lib/api";

let concerts = [];
try {
  const res = await fetch(`${getApiUrl()}/api/PageContent/concerts`);
  if (res.ok) {
    const doc = await res.json();
    let content = doc.content;
    if (typeof content === "string") {
      content = JSON.parse(content);
    }
    if (content && Array.isArray(content.items)) {
      concerts = content.items.map((c: any) => ({
        ...c,
        date: c.date ? new Date(c.date) : new Date(),
        slug: c.slug || c.id,
      }));
      concerts.sort((a, b) => a.date.getTime() - b.date.getTime());
    }
  }
} catch (e) {
  console.error("Failed to fetch concerts", e);
}

// Slice as per original Angular template logic
const recentActualites = actualites.slice(0, 3);
const recentConcerts = concerts.slice(0, 3);
---

<Layout title="Association Adonf - École de musique & Concerts">
  <main class="section-layout">
    <!-- Hero/Welcome Section could go here, omitting as source was section-layout focused -->

    <section class="actualites-section">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Actualités</h2>
          </div>
          <a href={resolvePath("/agenda#actualites")} class="btn btn-outline">
            Toutes les actus <ArrowRightIcon className="w-4 h-4" />
          </a>
        </div>

        <div class="actualites-grid">
          {recentActualites.map((actu) => <ActualiteCard actualite={actu} featured={actu.featured} />)}
        </div>
      </div>
    </section>

    <section class="programmation-section">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Programmation</h2>
          </div>
          <a href={resolvePath("/agenda#programmation")} class="btn btn-outline">
            Toute la prog <ArrowRightIcon className="w-4 h-4" />
          </a>
        </div>

        <div class="concerts-grid">
          {recentConcerts.map((concert) => <ConcertCard concert={concert} />)}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style lang="scss">
  /* Extra styles if needed beyond global */
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
