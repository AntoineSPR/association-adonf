---
import Layout from "../layouts/Layout.astro";
import LessonCard from "../components/LessonCard.astro";
import ContactCard from "../components/ContactCard.astro";
import { resolvePath } from "@/lib/utils";
import { getApiUrl } from "../lib/api";

let projects: any[] = [];
let pageContent: any = {};
try {
  // Fetch contacts / page metadata
  const pageRes = await fetch(`${getApiUrl()}/api/PageContent/projet-pedagogique`);
  if (pageRes.ok) {
    const pageDoc = await pageRes.json();
    let content = pageDoc.content;
    if (typeof content === "string") content = JSON.parse(content);
    if (content) pageContent = content;
  }

  // Fetch the items collection
  const res = await fetch(`${getApiUrl()}/api/PageContent/projets-pedagogiques`);
  if (res.ok) {
    const doc = await res.json();
    let content = doc.content;
    if (typeof content === "string") {
      content = JSON.parse(content);
    }
    if (content && Array.isArray(content.items)) {
      projects = content.items;
    }
  }
} catch (err) {
  console.error("Failed to fetch projets", err);
}

projects = projects.map((project) => ({
  ...project,
  image: project.imageUrl || project.image,
  description: project.excerpt || project.description,
}));
---

<Layout title="Projet Pédagogique - Association Adonf">
  <div class="page-container">
    <div class="header-spacing"></div>

    <header class="page-header">
      <h1 class="main-title">
        PROJET <span>PÉDAGOGIQUE</span>
      </h1>
      <div class="title-underline"></div>
    </header>

    <!-- Grid -->
    <section class="projects-section">
      <div class="projects-container">
        {projects.map((project) => <LessonCard lesson={project} baseUrl={resolvePath("/projet-pedagogique")} />)}
      </div>
    </section>

    <!-- Contacts Section -->
    {
      pageContent.contacts && pageContent.contacts.length > 0 && (
        <section class="contacts-section">
          <h2 class="section-title">CONTACTS</h2>
          <div class="contacts-grid">
            {pageContent.contacts.map((contact: any) => (
              <ContactCard
                image={contact.image || "/assets/logo-adonf.png"}
                name={contact.name}
                role={contact.role}
                email={contact.email}
                phone={contact.phone}
              />
            ))}
          </div>
        </section>
      )
    }
  </div>
</Layout>

<style>
  /* Lessons Grid */
  .projects-section {
    margin-bottom: 6rem;
  }

  .projects-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }
</style>
