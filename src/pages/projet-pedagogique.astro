---
import EnConstruction from "../components/ui/EnConstruction.astro";
import { isEmptyContent } from "../lib/utils";
import Layout from "../layouts/Layout.astro";
import LessonCard from "../components/LessonCard.astro";
import ContactList from "../components/ContactList.astro";
import { resolvePath } from "@/lib/utils";
import { getApiUrl } from "../lib/api";

let projects: any[] = [];
let pageContent: any = {};
try {
  // Fetch contacts / page metadata
  const pageRes = await fetch(`${getApiUrl()}/api/PageContent/projet-pedagogique`);
  if (pageRes.ok) {
    const pageDoc = await pageRes.json();
    let content = pageDoc.content;
    if (typeof content === "string") content = JSON.parse(content);
    if (content) pageContent = content;
  }

  // Fetch the items collection
  const res = await fetch(`${getApiUrl()}/api/PageContent/projets-pedagogiques`);
  if (res.ok) {
    const doc = await res.json();
    let content = doc.content;
    if (typeof content === "string") {
      content = JSON.parse(content);
    }
    if (content && Array.isArray(content.items)) {
      projects = content.items;
    }
  }
} catch (err) {
  console.error("Failed to fetch projets", err);
}

projects = projects.map((project) => ({
  ...project,
  image: project.image,
  contenuHtml: project.extrait || project.contenuHtml,
}));
---

<Layout title="Projet Pédagogique - Association Adonf">
  <div class="page-container">
    <div class="header-spacing"></div>

    <header class="page-header">
      <h1 class="main-title">
        PROJET <span>PÉDAGOGIQUE</span>
      </h1>
      <div class="title-underline"></div>
    </header>
    {(isEmptyContent(pageContent) && (!projects || projects.length === 0)) ? <EnConstruction /> : (
      <>
        
    {pageContent.sections && pageContent.sections.length > 0 && (
      <div class="content-wrapper">
        {pageContent.sections.map((section: any) => (
          <section class="info-section">
            {section.titre && <h2 class="section-title">{section.titre}</h2>}
            <div class="text-container" set:html={section.contenuHtml} />
          </section>
        ))}
      </div>
    )}

    <!-- Grid -->
    <section class="projects-section">
      <div class="projects-container">
        {projects.map((project) => <LessonCard lesson={project} baseUrl={resolvePath("/projet-pedagogique")} />)}
      </div>
    </section>

    <!-- Contacts Section -->
    <ContactList contacts={pageContent.contacts} />
  
      </>
    )}
  </div>
</Layout>

<style>
  /* Lessons Grid */
  .projects-section {
    margin-bottom: 6rem;
  }

  .projects-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  /* Page Sections */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .info-section {
    background: #f9f9f9;
    padding: 2.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary-color, #dc143c);
  }

  .section-title {
    font-family: "Montserrat", sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #333;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .text-container :global(p) {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #555;
    margin-bottom: 1rem;
  }

  .text-container :global(ul) {
    list-style-type: disc;
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .text-container :global(li) {
    margin-bottom: 0.5rem;
    color: #555;
    font-size: 1.1rem;
  }
</style>
