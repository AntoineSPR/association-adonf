---
import Layout from "../../layouts/Layout.astro";
import { resolvePath } from "@/lib/utils";
import { getApiUrl } from "../../lib/api";

const { slug } = Astro.params;

let projects = [];
try {
  const res = await fetch(`${getApiUrl()}/api/PageContent/projets-pedagogiques`);
  if (res.ok) {
    const doc = await res.json();
    let content = doc.content;
    if (typeof content === "string") content = JSON.parse(content);
    if (content && Array.isArray(content.items)) {
      projects = content.items;
    }
  }
} catch (err) {
  console.error("Failed to fetch projets", err);
}

const projectData = projects.find((p) => p.slug === slug);

if (!projectData) {
  return Astro.redirect("/404");
}

const project = {
  ...projectData,
  image: projectData.image,
  contenu: projectData.contenuHtml || projectData.introduction || "",
  sections: projectData.sections?.map((s: any) => ({
    ...s,
    contenu: s.contenuHtml || s.contenu || "",
  })),
};
---

<Layout title={`${project.titre} - Projet Pédagogique Adonf`}>
  <div class="page-container">
    <div class="header-spacing"></div>

    <div class="project-detail-container">
      <div class="image-container">
        <img src={project.image} alt={project.titre} transition:name={`project-image-${project.slug}`} />
        <div class="project-title-overlay">
          <h1>{project.titre}</h1>
        </div>
      </div>

      <div class="project-content">
        {
          project.contenu && (
            <div class="main-text text-lg">
              <div set:html={project.contenu} />
            </div>
          )
        }

        {
          project.sections &&
            project.sections.map((section: any) => (
              <div class="custom-section">
                <h2 class="section-title">{section.titre}</h2>
                <div class="section-text text-lg">
                  <div set:html={section.contenu} />
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <div class="back-link">
      <a href={resolvePath("/projet-pedagogique")}>&larr; Retour aux projets</a>
    </div>
  </div>
</Layout>

<style>
  .header-spacing {
    height: 40px;
  }

  .project-detail-container {
    max-width: 900px;
    margin: 0 auto 4rem auto;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .image-container {
    width: 100%;
    height: 400px;
    overflow: hidden;
    position: relative;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-title-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    padding: 2rem;
    color: white;
  }

  .project-title-overlay h1 {
    margin: 0;
    font-size: 3rem;
    font-family: "Montserrat", sans-serif;
    text-transform: uppercase;
    font-weight: 800;
  }

  .project-content {
    padding: 2.5rem;
  }

  .main-text {
    font-size: 1.25rem;
    line-height: 1.6;
    font-weight: 500;
    color: #333;
    margin-bottom: 3rem;
  }

  .custom-section {
    margin-bottom: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .section-title {
    font-family: "Montserrat", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    position: relative;
    display: inline-block;
  }

  .section-titre::after {
    content: "";
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 40px;
    height: 3px;
    background-color: var(--primary-color, #dc143c);
  }

  .section-text p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #555;
    margin-bottom: 0.5rem;
  }

  .contact-section {
    max-width: 900px;
    margin: 0 auto 4rem auto;
    text-align: center;
  }

  .contact-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: #333;
    text-transform: uppercase;
  }

  .contact-wrapper {
    max-width: 450px;
    margin: 0 auto;
  }

  .back-link {
    text-align: center;
    margin-bottom: 4rem;
  }

  .back-link a {
    color: #666;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s;
  }

  .back-link a:hover {
    color: var(--primary-color, #dc143c);
  }

  @media (max-width: 768px) {
    .image-container {
      height: 250px;
    }
    .project-title-overlay h1 {
      font-size: 2rem;
    }
    .project-content {
      padding: 1.5rem;
    }
  }
</style>
